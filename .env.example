# Django
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — Django reads these
DB_NAME=campuscart_db
DB_USER=campuscart_user
DB_PASSWORD=campuscart_pass123
DB_HOST=db
DB_PORT=5432

# Database — PostgreSQL container reads these
POSTGRES_DB=campuscart_db
POSTGRES_USER=campuscart_user
POSTGRES_PASSWORD=campuscart_pass123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Email
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# Stripe
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# VAPID — generate your own with: vapid --gen (from the py-vapid package)
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_EMAIL=mailto:admin@example.com

# Frontend
FRONTEND_URL=http://localhost:8080

# Superuser bootstrap (optional — only created if both are set)
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=choose-a-real-password
DJANGO_SUPERUSER_NAME=Admin